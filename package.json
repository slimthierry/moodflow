{
  "name": "moodflow",
  "version": "0.1.0",
  "private": true,
  "description": "MoodFlow - Mood and Mental Well-being Tracking Application",
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "pnpm --filter @moodflow/web dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "prettier": "^3.2.4",
    "turbo": "^2.0.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
